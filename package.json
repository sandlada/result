{
    "name": "@sandlada/result",
    "version": "0.0.1-20260702.a",
    "description": "Type-safe Result pattern for TypeScript — explicit error handling without exceptions",
    "type": "module",
    "main": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
        ".": {
            "types": "./build/index.d.ts",
            "default": "./build/index.js"
        },
        "./fp": {
            "types": "./build/fp/index.d.ts",
            "default": "./build/fp/index.js"
        },
        "./promise": {
            "types": "./build/promise/index.d.ts",
            "default": "./build/promise/index.js"
        },
        "./fp/promise": {
            "types": "./build/fp/promise/index.d.ts",
            "default": "./build/fp/promise/index.js"
        },
        "./option": {
            "types": "./build/Option.d.ts",
            "default": "./build/Option.js"
        },
        "./fp/option": {
            "types": "./build/fp/option/index.d.ts",
            "default": "./build/fp/option/index.js"
        },
        "./*": {
            "types": "./build/*.d.ts",
            "default": "./build/*.js"
        }
    },
    "files": [
        "build/",
        "README.md",
        "LICENSE",
        "CODE_OF_CONDUCT.md",
        "SECURITY.md"
    ],
    "scripts": {
        "build": "tsgo --project tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sandlada/result.git"
    },
    "bugs": {
        "url": "https://github.com/sandlada/result/issues"
    },
    "homepage": "https://github.com/sandlada/result#readme",
    "keywords": [
        "result",
        "either",
        "error-handling",
        "functional",
        "typescript"
    ],
    "publishConfig": {
        "access": "public"
    },
    "author": "Kai-Orion & Sandlada",
    "license": "MIT",
    "devDependencies": {
        "@typescript/native-preview": "^7.0.0-dev.20260630.1",
        "vitest": "^4.1.9"
    }
}
