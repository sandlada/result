{
    "name": "@sandlada/result",
    "version": "0.0.3-20260716.a",
    "description": "Type-safe Result Pattern & ROP for TypeScript — Explicit Error Handling without Exceptions",
    "type": "module",
    "main": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
        ".": {
            "types": "./build/index.d.ts",
            "default": "./build/index.js"
        },
        "./option": {
            "types": "./build/option/index.d.ts",
            "default": "./build/option/index.js"
        },
        "./types": {
            "types": "./build/types/index.d.ts",
            "default": "./build/types/index.js"
        },
        "./factories": {
            "types": "./build/factories/index.d.ts",
            "default": "./build/factories/index.js"
        },
        "./operators": {
            "types": "./build/operators/index.d.ts",
            "default": "./build/operators/index.js"
        },
        "./async": {
            "types": "./build/async/index.d.ts",
            "default": "./build/async/index.js"
        },
        "./composition": {
            "types": "./build/composition/index.d.ts",
            "default": "./build/composition/index.js"
        },
        "./adapters": {
            "types": "./build/adapters/index.d.ts",
            "default": "./build/adapters/index.js"
        },
        "./combine": {
            "types": "./build/combine/index.d.ts",
            "default": "./build/combine/index.js"
        },
        "./async-result": {
            "types": "./build/async-result/index.d.ts",
            "default": "./build/async-result/index.js"
        },
        "./async-option": {
            "types": "./build/async-option/index.d.ts",
            "default": "./build/async-option/index.js"
        }
    },
    "files": [
        "build/",
        "README.md",
        "LICENSE",
        "CODE_OF_CONDUCT.md",
        "SECURITY.md"
    ],
    "scripts": {
        "build": "tsgo --project tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "bench": "vitest bench",
        "bench:json": "vitest bench --outputJson=bench/results.json",
        "bench:ui": "vitest bench --ui"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sandlada/result.git"
    },
    "bugs": {
        "url": "https://github.com/sandlada/result/issues"
    },
    "homepage": "https://github.com/sandlada/result#readme",
    "keywords": [
        "result",
        "result-pattern",
        "rop",
        "option",
        "async",
        "async-result",
        "either",
        "error-handling",
        "functional",
        "typescript"
    ],
    "publishConfig": {
        "access": "public"
    },
    "author": "Kai-Orion & Sandlada",
    "license": "MIT",
    "devDependencies": {
        "@typescript/native-preview": "^7.0.0-dev.20260704.1",
        "@vitest/ui": "^4.1.9",
        "vitest": "^4.1.9"
    }
}
